import json
import boto3
import logging
import urllib3
import os
from datetime import datetime

# Configuração de Logs
logger = logging.getLogger()
logger.setLevel(logging.INFO)
http = urllib3.PoolManager()

# Configuração DynamoDB
DDB_TABLE = os.environ.get("DDB_TABLE", "ClientsOnboarding")
dynamodb = boto3.resource("dynamodb")
table = dynamodb.Table(DDB_TABLE)

def lambda_handler(event, context):
    logger.info(f"Evento recebido: {json.dumps(event)}")

    request_type = event.get("RequestType")
    props = event.get("ResourceProperties", {})

    # Captura de dados
    client_account_id = props.get("ClientAccountId")
    role_name = props.get("RoleName")
    
    # Tratamento rigoroso do ExternalId para evitar strings "None" ou vazias
    raw_external_id = props.get("ExternalId")
    if not raw_external_id or str(raw_external_id).strip().lower() in ["", "none"]:
        external_id = None
    else:
        external_id = str(raw_external_id).strip()

    client_name = props.get("ClientName", props.get("StackName"))
    stack_name = props.get("StackName")

    status = "SUCCESS"

    try:
        if request_type == "Delete":
            if client_account_id:
                table.delete_item(Key={"account_id": client_account_id})
                logger.info(f"Registro deletado para a conta: {client_account_id}")

        elif request_type in ["Create", "Update"]:
            timestamp = datetime.now().isoformat()
            
            # 1. Montagem do Link Cross-Account LIMPO (sem externalId se for vazio)
            base_url = f"https://signin.aws.amazon.com/switchrole?roleName={role_name}&account={client_account_id}"
            
            if external_id:
                cross_account_link = f"{base_url}&externalId={external_id}"
            else:
                cross_account_link = base_url

            # 2. Salvar no DynamoDB (apenas campos essenciais)
            item = {
                "account_id": client_account_id,
                "client_name": client_name,
                "role_name": role_name,
                "external_id": external_id if external_id else "",
                "stack_name": stack_name,
                "cross_account_link": cross_account_link,
                "updated_at": timestamp
            }
            
            table.put_item(Item=item)
            logger.info(f"Registro salvo com sucesso para {client_name}. Link: {cross_account_link}")

    except Exception as e:
        logger.error(f"Erro ao processar: {str(e)}")
        status = "FAILED"

    finally:
        send_response(event, context, status)

def send_response(event, context, response_status):
    response_url = event["ResponseURL"]
    response_body = json.dumps({
        "Status": response_status,
        "Reason": f"Logs: {context.log_stream_name}",
        "PhysicalResourceId": event.get("PhysicalResourceId", context.log_stream_name),
        "StackId": event["StackId"],
        "RequestId": event["RequestId"],
        "LogicalResourceId": event["LogicalResourceId"],
        "Data": {}
    })
    headers = {"Content-Type": "", "Content-Length": str(len(response_body))}
    http.request("PUT", response_url, body=response_body.encode('utf-8'), headers=headers)
